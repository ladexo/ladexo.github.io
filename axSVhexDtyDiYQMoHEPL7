  <script>
/* ========================================
   OloladeSec — Main JavaScript
   ======================================== */

// ===== Mobile Nav Toggle =====
const navToggle = document.querySelector('.nav-toggle');
const navLinks = document.querySelector('.nav-links');

if (navToggle) {
  navToggle.addEventListener('click', () => {
    navToggle.classList.toggle('active');
    navLinks.classList.toggle('open');
  });

  document.querySelectorAll('.nav-links a').forEach(link => {
    link.addEventListener('click', () => {
      navToggle.classList.remove('active');
      navLinks.classList.remove('open');
    });
  });
}

// ===== Navbar Scroll Effect =====
const navbar = document.querySelector('.navbar');
window.addEventListener('scroll', () => {
  if (window.scrollY > 50) {
    navbar.classList.add('scrolled');
  } else {
    navbar.classList.remove('scrolled');
  }
});

// ===== Fade-In on Scroll =====
const fadeEls = document.querySelectorAll('.fade-in');
const fadeObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

fadeEls.forEach(el => fadeObserver.observe(el));

// ===== Stat Counter Animation =====
const statNumbers = document.querySelectorAll('.stat-number');
const statObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const el = entry.target;
      const target = parseInt(el.dataset.target);
      const suffix = el.dataset.suffix || '';
      let current = 0;
      const increment = Math.ceil(target / 60);
      const timer = setInterval(() => {
        current += increment;
        if (current >= target) {
          current = target;
          clearInterval(timer);
        }
        el.textContent = current.toLocaleString() + suffix;
      }, 25);
      statObserver.unobserve(el);
    }
  });
}, { threshold: 0.5 });

statNumbers.forEach(el => statObserver.observe(el));

// ===== Terminal Typing Effect =====
const typingEl = document.querySelector('.typing-text');
if (typingEl) {
  const commands = [
    'nmap -sV --script vuln target.com',
    'sudo tcpdump -i eth0 -w capture.pcap',
    'hashcat -m 0 -a 0 hashes.txt wordlist.txt',
    'nikto -h https://target.com -ssl',
    'gobuster dir -u https://target.com -w common.txt',
    'sqlmap -u "https://target.com/page?id=1" --dbs',
    'hydra -l admin -P passwords.txt ssh://target.com',
    'wireshark -k -i eth0 -f "port 443"'
  ];
  let cmdIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  let pauseTimer = 0;

  function typeLoop() {
    const currentCmd = commands[cmdIndex];

    if (!isDeleting) {
      typingEl.textContent = currentCmd.substring(0, charIndex + 1);
      charIndex++;

      if (charIndex === currentCmd.length) {
        isDeleting = true;
        pauseTimer = 60;
      }
    } else {
      if (pauseTimer > 0) {
        pauseTimer--;
      } else {
        typingEl.textContent = currentCmd.substring(0, charIndex - 1);
        charIndex--;

        if (charIndex === 0) {
          isDeleting = false;
          cmdIndex = (cmdIndex + 1) % commands.length;
        }
      }
    }

    const speed = isDeleting ? (pauseTimer > 0 ? 30 : 20) : 50 + Math.random() * 40;
    setTimeout(typeLoop, speed);
  }

  setTimeout(typeLoop, 1000);
}

// ===== Password Strength Checker =====
const passwordInput = document.getElementById('passwordInput');
const toggleBtn = document.querySelector('.toggle-visibility');

if (passwordInput) {
  // Toggle visibility
  if (toggleBtn) {
    toggleBtn.addEventListener('click', () => {
      const type = passwordInput.type === 'password' ? 'text' : 'password';
      passwordInput.type = type;
      toggleBtn.textContent = type === 'password' ? '👁️' : '🔒';
    });
  }

  // Common passwords list
  const commonPasswords = new Set([
    'password', '123456', '12345678', 'qwerty', 'abc123', 'monkey', 'master',
    'dragon', '111111', 'baseball', 'iloveyou', 'trustno1', 'sunshine', 'ashley',
    'football', 'shadow', '123123', '654321', 'superman', 'qazwsx', 'michael',
    'password1', 'password123', 'admin', 'letmein', 'welcome', 'login', 'starwars',
    '1234567', '12345', '1234567890', '000000', 'passw0rd', 'hello', 'charlie'
  ]);

  passwordInput.addEventListener('input', () => {
    const pw = passwordInput.value;
    const fill = document.querySelector('.meter-bar-fill');
    const strengthText = document.querySelector('.strength-text');
    const crackTime = document.querySelector('.crack-time');

    // Criteria checks
    const criteria = {
      length: pw.length >= 12,
      upper: /[A-Z]/.test(pw),
      lower: /[a-z]/.test(pw),
      number: /\d/.test(pw),
      special: /[^A-Za-z0-9]/.test(pw),
      nocommon: !commonPasswords.has(pw.toLowerCase())
    };

    // Update criteria UI
    Object.keys(criteria).forEach(key => {
      const el = document.getElementById('cr-' + key);
      if (el) {
        if (criteria[key]) {
          el.classList.add('met');
        } else {
          el.classList.remove('met');
        }
      }
    });

    // Score calculation
    if (pw.length === 0) {
      fill.style.width = '0%';
      fill.style.background = 'transparent';
      strengthText.textContent = '—';
      strengthText.style.color = 'var(--text-muted)';
      crackTime.textContent = '';
      return;
    }

    let score = 0;
    Object.values(criteria).forEach(v => { if (v) score++; });

    // Bonus for length
    if (pw.length >= 16) score += 1;
    if (pw.length >= 20) score += 1;

    // Calculate crack time estimate
    let charsetSize = 0;
    if (/[a-z]/.test(pw)) charsetSize += 26;
    if (/[A-Z]/.test(pw)) charsetSize += 26;
    if (/\d/.test(pw)) charsetSize += 10;
    if (/[^A-Za-z0-9]/.test(pw)) charsetSize += 33;
    if (charsetSize === 0) charsetSize = 26;

    const combinations = Math.pow(charsetSize, pw.length);
    const gpuSpeed = 10e9; // 10 billion guesses/sec (modern GPU)
    const seconds = combinations / gpuSpeed;

    let timeStr = '';
    if (seconds < 0.001) timeStr = 'Instantly';
    else if (seconds < 1) timeStr = 'Under 1 second';
    else if (seconds < 60) timeStr = Math.ceil(seconds) + ' seconds';
    else if (seconds < 3600) timeStr = Math.ceil(seconds / 60) + ' minutes';
    else if (seconds < 86400) timeStr = Math.ceil(seconds / 3600) + ' hours';
    else if (seconds < 31536000) timeStr = Math.ceil(seconds / 86400) + ' days';
    else if (seconds < 31536000 * 1000) timeStr = Math.ceil(seconds / 31536000) + ' years';
    else if (seconds < 31536000 * 1e6) timeStr = Math.ceil(seconds / 31536000 / 1000) + 'K years';
    else if (seconds < 31536000 * 1e9) timeStr = Math.ceil(seconds / 31536000 / 1e6) + 'M years';
    else timeStr = '∞ (centuries+)';

    // Determine level
    let level, color, width;
    if (score <= 2) { level = 'Weak'; color = '#ef4444'; width = '20%'; }
    else if (score <= 3) { level = 'Fair'; color = '#f97316'; width = '40%'; }
    else if (score <= 5) { level = 'Good'; color = '#facc15'; width = '60%'; }
    else if (score <= 6) { level = 'Strong'; color = '#00ff88'; width = '80%'; }
    else { level = 'Excellent'; color = '#00e5ff'; width = '100%'; }

    // Common password override
    if (!criteria.nocommon) {
      level = 'Compromised';
      color = '#ef4444';
      width = '10%';
      timeStr = 'Instantly (in breach databases)';
    }

    fill.style.width = width;
    fill.style.background = color;
    strengthText.textContent = level;
    strengthText.style.color = color;
    crackTime.textContent = 'Est. crack time (GPU): ' + timeStr;
  });
}

// ===== Password Generator =====
const genLength = document.getElementById('genLength');
const genOutput = document.getElementById('genOutput');
const genBtn = document.querySelector('.btn-generate');
const copyBtn = document.querySelector('.btn-copy');
const lengthValue = document.querySelector('.length-value');

if (genLength && lengthValue) {
  genLength.addEventListener('input', () => {
    lengthValue.textContent = genLength.value;
  });
}

if (genBtn) {
  genBtn.addEventListener('click', () => {
    const len = parseInt(genLength.value);
    let chars = '';
    if (document.getElementById('genUpper').checked) chars += 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    if (document.getElementById('genLower').checked) chars += 'abcdefghijklmnopqrstuvwxyz';
    if (document.getElementById('genNumbers').checked) chars += '0123456789';
    if (document.getElementById('genSymbols').checked) chars += '!@#$%^&*()_+-=[]{}|;:,.<>?';

    if (chars.length === 0) {
      genOutput.value = 'Select at least one character type';
      return;
    }

    const array = new Uint32Array(len);
    crypto.getRandomValues(array);
    let password = '';
    for (let i = 0; i < len; i++) {
      password += chars[array[i] % chars.length];
    }
    genOutput.value = password;

    // Flash effect
    genOutput.style.borderColor = 'var(--accent-green)';
    setTimeout(() => { genOutput.style.borderColor = 'var(--border-subtle)'; }, 800);
  });
}

if (copyBtn) {
  copyBtn.addEventListener('click', () => {
    if (genOutput && genOutput.value && genOutput.value !== 'Click Generate...' && genOutput.value !== 'Select at least one character type') {
      navigator.clipboard.writeText(genOutput.value).then(() => {
        const original = copyBtn.textContent;
        copyBtn.textContent = '✓ Copied';
        copyBtn.style.color = 'var(--accent-green)';
        copyBtn.style.borderColor = 'var(--accent-green)';
        setTimeout(() => {
          copyBtn.textContent = original;
          copyBtn.style.color = '';
          copyBtn.style.borderColor = '';
        }, 2000);
      });
    }
  });
}

</script>
